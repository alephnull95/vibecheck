# ── Local Docker Registry ─────────────────────
# IP of the machine running the local registry (your Mac Mini)
# e.g. 192.168.1.50:5000
REGISTRY_HOST=192.168.1.50:5000

# ── PostgreSQL ───────────────────────────────
POSTGRES_USER=vibecheck
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=vibecheck
DATABASE_URL=postgresql+psycopg2://vibecheck:changeme_strong_password@db:5432/vibecheck

# ── Redis / Celery ───────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Radarr ───────────────────────────────────
RADARR_URL=http://radarr:7878
RADARR_API_KEY=your_radarr_api_key_here

# ── Plex ─────────────────────────────────────
PLEX_URL=http://plex:32400
PLEX_TOKEN=your_plex_token_here

# ── TMDB ─────────────────────────────────────
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_ACCESS_TOKEN=your_tmdb_read_access_token_here

# ── OpenAI ───────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Gemini (alternative LLM) ─────────────────
# Set LLM_PROVIDER=gemini and fill this to use Gemini instead of OpenAI
GEMINI_API_KEY=your_gemini_api_key_here

# ── LLM Provider: "openai" | "gemini" ────────
LLM_PROVIDER=openai
# For embeddings, always uses OpenAI text-embedding-3-small (1536 dims)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── Overseerr ────────────────────────────────
OVERSEERR_URL=http://overseerr:5055
OVERSEERR_API_KEY=your_overseerr_api_key_here

# ── App ──────────────────────────────────────
APP_ENV=production               # development | production | test
SECRET_KEY=changeme_random_secret_key_here
LOG_LEVEL=INFO

# ── Search tuning (optional) ─────────────────
# DISCOVERY_THRESHOLD=5          # min local results before TMDB fallback kicks in
# VECTOR_DISTANCE_CUTOFF=0.55    # cosine distance cutoff (0=identical, 2=opposite)
# FEEDBACK_FEW_SHOT_COUNT=5      # liked examples injected into query expansion

# Minimum local results before triggering TMDB discovery fallback
DISCOVERY_THRESHOLD=5
